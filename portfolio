<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Fukui Toshiki | Portfolio</title>

  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;600&display=swap" rel="stylesheet">

  <style>
    body {
      margin: 0;
      font-family: 'Noto Sans JP', sans-serif;
      background: #f7f7f7;
      color: #333;
      line-height: 1.6;
    }

    header {
      height: 100vh;
      background: url('https://images.unsplash.com/photo-1492724441997-5dc865305da7') center/cover no-repeat;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      color: white;
    }

    header h1 {
      font-size: 42px;
      margin-bottom: 10px;
    }

    header p {
      font-size: 18px;
      opacity: 0.9;
    }

    .btn {
      display: inline-block;
      margin-top: 20px;
      padding: 12px 28px;
      background: #ffffff;
      color: #333;
      text-decoration: none;
      border-radius: 30px;
      transition: 0.3s;
    }

    .btn:hover {
      background: #333;
      color: white;
    }

    section {
      padding: 80px 20px;
      max-width: 1000px;
      margin: auto;
    }

    h2 {
      text-align: center;
      margin-bottom: 40px;
      font-weight: 600;
    }

    .about {
      text-align: center;
      max-width: 700px;
      margin: auto;
    }

    .works {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 20px;
    }

    .card {
      background: white;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 5px 15px rgba(0,0,0,0.05);
      transition: 0.3s;
    }

    .card:hover {
      transform: translateY(-5px);
    }

    .card img {
      width: 100%;
      display: block;
    }

    .card p {
      padding: 15px;
    }

    footer {
      text-align: center;
      padding: 40px 20px;
      font-size: 14px;
      color: #777;
    }
  </style>
</head>

<body>

  <!-- Hero -->
  <header>
    <div>
      <h1>Toshiki Fukui</h1>
      <p>デザインで「伝わる」をつくるWebデザイナー</p>
      <a href="#works" class="btn">作品を見る</a>
    </div>
  </header>

  <!-- About -->
  <section>
    <h2>About</h2>
    <div class="about">
      <p>
        はじめまして。Webデザイナーの福井利希です。<br>
        ナイトレジャー業界での制作経験を活かし、<br>
        「目に留まる」「選ばれる」デザインを意識して制作しています。
      </p>
      <p>
        バナー制作・Webサイト更新・SNS投稿など、<br>
        幅広く対応可能です。
      </p>
    </div>
  </section>

  <!-- Works -->
  <section id="works">
    <h2>Works</h2>
    <div class="works">

      <div class="card">
        <img src="https://images.unsplash.com/photo-1559027615-cd4628902d4a" alt="">
        <p>バナー制作 / 集客用広告デザイン</p>
      </div>

      <div class="card">
        <img src="https://images.unsplash.com/photo-1529336953121-ad5a0d43d0d2" alt="">
        <p>Webサイト更新・運用</p>
      </div>

      <div class="card">
        <img src="https://images.unsplash.com/photo-1519389950473-47ba0277781c" alt="">
        <p>SNS投稿デザイン（X・Instagram）</p>
      </div>

    </div>
  </section>

  <!-- Contact -->
  <section>
    <h2>Contact</h2>
    <div class="about">
      <p>
        お仕事のご相談はお気軽にご連絡ください。<br>
        スピード感を持って丁寧に対応いたします。
      </p>
      <a href="#" class="btn">お問い合わせ</a>
    </div>
  </section>

  <footer>
    © 2026 Toshiki Fukui
  </footer>

</body>
</html>
